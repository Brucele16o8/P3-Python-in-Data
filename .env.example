APP_ENV=local
DB_SETUP_MODE=docker_managed
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_oltp
DB_USER=postgres
DB_PASSWORD=postgres
DB_CONNECT_RETRIES=15
DB_RETRY_DELAY_SECONDS=2
FAKER_LOCALE=vi_VN
LOG_LEVEL=INFO
RANDOM_SEED=42
BATCH_SIZE=500
RESET_TABLES=false
ALLOW_DESTRUCTIVE_RESET=false
GEN_BRANDS=20
GEN_CATEGORIES=10
GEN_SELLERS=25
GEN_PRODUCTS=2000
GEN_PROMOTIONS=10
GEN_PROMOTION_PRODUCTS=100
